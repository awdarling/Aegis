# Aegis environment variables
# Copy this file to .env and fill in real values — never commit .env

# ── Runtime ───────────────────────────────────────────────────────────────────
# "development" | "production" | "test"
NODE_ENV=production

# Port the HTTP server listens on. Railway injects $PORT automatically.
PORT=3000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Full project URL from Supabase → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co

# Service role key from Supabase → Settings → API → Project API keys.
# This key bypasses Row Level Security — never expose it client-side.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Twilio ────────────────────────────────────────────────────────────────────
# Account SID from the Twilio Console dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth Token from the Twilio Console dashboard.
# Also used to verify the HMAC-SHA1 signature on inbound webhook requests.
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# ── SendGrid ──────────────────────────────────────────────────────────────────
# API key with Mail Send and Inbound Parse permissions
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Must be a verified sender identity or authenticated domain in SendGrid
SENDGRID_FROM_EMAIL=aegis@mail.yourdomain.com

# Display name shown in the From field of outbound emails (optional, default: Aegis)
SENDGRID_FROM_NAME=Aegis

# Optional: SendGrid signed event webhook verification key for inbound parse
# Found in SendGrid → Settings → Inbound Parse → Signature Verification
SENDGRID_WEBHOOK_VERIFICATION_KEY=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Service ───────────────────────────────────────────────────────────────────
# Public HTTPS URL of this deployed service — no trailing slash.
# Required in production: used to generate Approve/Deny links in manager emails.
# Example: https://aegis-production.up.railway.app
BASE_URL=https://your-aegis-url.up.railway.app

# Base URL of the Homebase Next.js app (no trailing slash).
# Used by aegis-actions to construct magic-link URLs that point back to Homebase
# (e.g. one-click TO approve/deny, availability approve/deny, emergency coverage).
# Example: https://homebase-nine-phi.vercel.app
HOMEBASE_URL=https://homebase-nine-phi.vercel.app
